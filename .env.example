# Telegram Bot Token (from @BotFather)
TOKEN=your_telegram_bot_token_here

# VK API Token (from vk.com/dev)
VK_TOKEN=your_vk_api_token_here

# Telegram user ID of the bot administrator
ADMIN_ID=your_telegram_user_id_here

# VK group domain to monitor (without @)
GROUP_ID=vrv_radar

# Interval in seconds between VK polling requests (default: 60)
POLL_INTERVAL=60
